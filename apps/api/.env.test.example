# Integration test environment
# Copy to .env.test: cp .env.test.example .env.test

# Database (docker-compose.test.yml)
DATABASE_URL=mysql://test:test@127.0.0.1:3307/school_test
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USERNAME=test
MYSQL_PASSWORD=test
MYSQL_SCHEMA=school_test
# 테스트 커넥션 풀 (선택, default 10, 범위 1~100)
MYSQL_CONNECTION_LIMIT=5

# App
APP_NAME=test
APP_PORT=3000

# JWT
JWT_SECRET=test-secret-key-for-integration-tests
JWT_EXPIRE_ACCESS=1h
JWT_EXPIRE_REFRESH=7d

# 테스트 환경: off로 운영 → query 이벤트 자체 비활성화
DB_QUERY_LOGGING=off

# DB 타임아웃 (테스트: 짧게 권장)
# DB_CONNECT_TIMEOUT_MS=2000
# DB_IDLE_TIMEOUT_SEC=60
# DB_TRANSACTION_TIMEOUT_MS=5000
# DB_TRANSACTION_MAX_WAIT_MS=2000
