#
# e2e 테스트 전용 API 서버 환경변수
#
# 사용법: 이 파일을 .env.test-e2e로 복사하고 로컬 MySQL 자격증명을 채운다.
# NODE_ENV=test-e2e로 기동하면 env.ts postfix 규칙에 따라 .env.test-e2e가 로드된다.
# (NODE_ENV에 "test"가 포함되어 스케줄러/일일 메일이 자동 비활성화된다)
#
# 주의: MYSQL_SCHEMA는 반드시 "e2e"를 포함해야 한다.
# scripts/start-e2e.cjs가 force-reset 전에 검증한다 (실DB 보호 가드).
#

#
# APPLICATION
#
APP_NAME=school-manage-e2e
# 9000 고정: apps/web vite dev proxy(/trpc -> localhost:9000)와 맞춰야 한다
APP_PORT=9000

#
# MYSQL
#
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=changeme
MYSQL_SCHEMA=school_e2e

#
# JWT (e2e 전용 임의 값)
#
JWT_SECRET=e2e-secret-key
JWT_EXPIRE_ACCESS=1h
JWT_EXPIRE_REFRESH=14d

# GA4/SMTP/CORS는 의도적으로 미설정:
# - GA4 미설정 -> 측정 이벤트 미발화 (실측 지표 오염 방지)
# - SMTP 미설정 -> 메일 발송 비활성
# - CORS 미설정 -> vite proxy로 same-origin 통신이라 불필요
