#
# APPLICATION
#
APP_NAME=school-manage-back
APP_PORT=5000

#
# MONGODB
#
MONGODB_URL=mongodb://localhost:27017/feedings
# MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.cmyck5l.mongodb.net/?retryWrites=true&w=majority

#
# MYSQL
#
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=change_me
MYSQL_PASSWORD=change_me
MYSQL_SCHEMA=change_me

#
# PRISMA
#
DATABASE_URL="mysql://change_me:change_me@localhost:3306/change_me"

# JWT
JWT_SECRET=change_me
JWT_EXPIRE_ACCESS=12h
JWT_EXPIRE_REFRESH=14d

# GA4  - 프로덕션 전용, 미설정 시 비활성화
GA4_MEASUREMENT_ID=change_me
GA4_API_SECRET=change_me

# Google SMTP (회원가입 알림) - 프로덕션 전용, 미설정 시 비활성화
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
ADMIN_EMAIL=admin@example.com

# DB 쿼리 로깅 - off | slow | all (default: slow)
# off: query 이벤트 비활성 (슬로우 쿼리 감지 X). slow: 슬로우 쿼리(>=1000ms)만. all: 모든 쿼리 (local 개발용)
DB_QUERY_LOGGING=slow
