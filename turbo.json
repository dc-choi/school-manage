{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "cacheDir": ".turbo/cache",
  "globalDependencies": ["**/.env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@school/api#prisma:generate": {
      "cache": false
    },
    "@school/api#build": {
      "dependsOn": ["@school/api#prisma:generate", "^build"],
      "outputs": ["dist/**"]
    },
    "@school/web#build": {
      "dependsOn": ["@school/api#build", "^build"],
      "outputs": ["dist/**"]
    },
    "start": {
      "dependsOn": ["^build", "^start"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "@school/api#typecheck": {
      "dependsOn": ["@school/api#prisma:generate", "^build"]
    },
    "@school/web#typecheck": {
      "dependsOn": ["@school/api#build", "^build"]
    },
    "dev": {
      "dependsOn": ["@school/shared#build", "@school/trpc#build"],
      "cache": false,
      "persistent": true
    },
    "dev:trpc": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "@school/api#test": {
      "dependsOn": ["@school/api#prisma:generate", "^build"]
    },
    "clean": {
      "dependsOn": ["^clean"]
    }
  }
}
